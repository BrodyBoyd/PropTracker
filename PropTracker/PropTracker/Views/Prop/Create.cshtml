@model PropTracker.Models.Prop
@using PropTracker.Models

@{
    ViewData["Title"] = "Add Prop";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PropTracker — Add Prop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0c10;
            --bg2: #12151c;
            --bg3: #1a1e29;
            --border: rgba(255,255,255,0.07);
            --border2: rgba(255,255,255,0.14);
            --accent: #00e5a0;
            --gold: #f5c842;
            --text: #e8eaf2;
            --muted: #7a7f94;
            --red: #ff4d6d;
            --error-bg: rgba(255,77,109,0.08);
            --error-border: rgba(255,77,109,0.4);
            --over: #00e5a0;
            --under: #ff4d6d;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Barlow', sans-serif;
            min-height: 100vh;
        }

        nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 32px;
            border-bottom: 1px solid var(--border);
            background: var(--bg);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 900;
            font-size: 22px;
            letter-spacing: 1px;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .logo-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); }
        .nav-links { display: flex; gap: 28px; list-style: none; }

        .nav-links a {
            font-size: 13px;
            font-weight: 500;
            color: var(--muted);
            text-decoration: none;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            transition: color .2s;
        }

        .nav-links a:hover { color: var(--text); }
        .nav-links a.active { color: var(--accent); }

        .nav-back {
            background: transparent;
            color: var(--muted);
            border: 1px solid var(--border2);
            padding: 7px 16px;
            border-radius: 6px;
            font-family: 'Barlow', sans-serif;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            text-decoration: none;
            transition: color .15s;
        }

        .nav-back:hover { color: var(--text); }

        .page-layout {
            display: grid;
            grid-template-columns: 1fr 300px;
            min-height: calc(100vh - 53px);
        }

        .form-area { padding: 32px 36px; border-right: 1px solid var(--border); }

        .page-eyebrow {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: var(--accent);
            margin-bottom: 6px;
        }

        .page-title {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 900;
            font-size: 42px;
            text-transform: uppercase;
            letter-spacing: -0.5px;
            margin-bottom: 32px;
        }

        .section-label {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 700;
            font-size: 14px;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .section-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

        .divider { border: none; border-top: 1px solid var(--border); margin: 0 0 28px; }

        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 28px; }
        .form-group { display: flex; flex-direction: column; gap: 7px; }

        label {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--muted);
        }

        input[type="text"],
        input[type="number"] {
            background: var(--bg2);
            border: 1px solid var(--border2);
            border-radius: 6px;
            color: var(--text);
            font-family: 'Barlow', sans-serif;
            font-size: 15px;
            padding: 11px 14px;
            outline: none;
            transition: border-color .15s;
            width: 100%;
        }

        input[type="text"]:focus,
        input[type="number"]:focus { border-color: var(--accent); }
        input::placeholder { color: var(--muted); opacity: 1; }
        input.input-error { border-color: var(--error-border) !important; background: var(--error-bg) !important; }

        .field-validation-error { font-size: 12px; color: var(--red); margin-top: 4px; display: block; }

        /* PLAYER SEARCH */
        .player-search-wrap { position: relative; margin-bottom: 28px; }

        .player-search-input {
            width: 100%;
            background: var(--bg2);
            border: 1px solid var(--border2);
            border-radius: 6px;
            color: var(--text);
            font-family: 'Barlow', sans-serif;
            font-size: 15px;
            padding: 11px 40px 11px 14px;
            outline: none;
            transition: border-color .15s;
        }

        .player-search-input:focus { border-color: var(--accent); }
        .player-search-input::placeholder { color: var(--muted); }

        .search-spinner {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            width: 16px;
            height: 16px;
            border: 2px solid var(--border2);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin .6s linear infinite;
            display: none;
        }


        .player-dropdown {
            position: absolute;
            top: calc(100% + 4px);
            left: 0;
            right: 0;
            background: var(--bg2);
            border: 1px solid var(--border2);
            border-radius: 8px;
            overflow: hidden;
            z-index: 50;
            display: none;
        }

        .player-option {
            padding: 12px 14px;
            cursor: pointer;
            border-bottom: 1px solid var(--border);
            transition: background .1s;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .player-option:last-child { border-bottom: none; }
        .player-option:hover { background: var(--bg3); }

        .player-option-name {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 16px;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--text);
        }

        .player-option-team {
            font-size: 11px;
            color: var(--muted);
            background: var(--bg3);
            border: 1px solid var(--border2);
            padding: 2px 7px;
            border-radius: 3px;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .player-selected-badge {
            display: none;
            align-items: center;
            gap: 10px;
            background: rgba(0,229,160,0.08);
            border: 1px solid rgba(0,229,160,0.2);
            border-radius: 6px;
            padding: 10px 14px;
            margin-top: 8px;
        }

        .player-selected-badge.visible { display: flex; }

        .player-selected-name {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 15px;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--accent);
        }

        .player-clear {
            margin-left: auto;
            background: none;
            border: none;
            color: var(--muted);
            font-size: 13px;
            cursor: pointer;
            padding: 2px 6px;
            border-radius: 4px;
            transition: color .1s;
        }

        .player-clear:hover { color: var(--red); }

        .player-hint { font-size: 12px; color: var(--muted); margin-top: 6px; }

        /* BET TYPE */
        .bet-type-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 8px;
            margin-bottom: 28px;
        }

        .bet-type-btn {
            background: var(--bg2);
            border: 1px solid var(--border2);
            border-radius: 6px;
            color: var(--muted);
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 15px;
            font-weight: 700;
            letter-spacing: 1px;
            padding: 11px 6px 9px;
            text-align: center;
            cursor: pointer;
            transition: all .15s;
            user-select: none;
        }

        .bet-type-btn:hover { color: var(--text); }

        .bet-type-btn.selected {
            background: rgba(0,229,160,0.1);
            border-color: var(--accent);
            color: var(--accent);
        }

        .bet-type-sub {
            font-size: 9px;
            font-family: 'Barlow', sans-serif;
            font-weight: 400;
            letter-spacing: 0;
            color: var(--muted);
            margin-top: 3px;
            display: block;
            line-height: 1.2;
        }

        /* PROP VALUE + OVER/UNDER */
        .value-ou-row {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 12px;
            align-items: end;
            margin-bottom: 28px;
        }

        .value-wrap { position: relative; }

        .value-prefix {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 14px;
            color: var(--muted);
            pointer-events: none;
        }

        .value-input {
            padding-left: 36px !important;
            font-family: 'Barlow Condensed', sans-serif !important;
            font-size: 22px !important;
            font-weight: 700 !important;
            color: var(--gold) !important;
        }

        /* OVER/UNDER TOGGLE */
        .ou-toggle {
            display: flex;
            border: 1px solid var(--border2);
            border-radius: 6px;
            overflow: hidden;
            height: 46px;
        }

        .ou-btn {
            flex: 1;
            background: var(--bg2);
            border: none;
            color: var(--muted);
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 1px;
            padding: 0 18px;
            cursor: pointer;
            transition: all .15s;
            user-select: none;
            white-space: nowrap;
        }

        .ou-btn:first-child { border-right: 1px solid var(--border2); }

        .ou-btn.over.selected {
            background: rgba(0,229,160,0.12);
            color: var(--over);
        }

        .ou-btn.under.selected {
            background: rgba(255,77,109,0.1);
            color: var(--under);
        }

        /* PARLAY TOGGLE */
        .toggle-row { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }

        .toggle { position: relative; width: 42px; height: 24px; cursor: pointer; flex-shrink: 0; }
        .toggle input { opacity: 0; width: 0; height: 0; position: absolute; }

        .slider {
            position: absolute;
            inset: 0;
            background: var(--bg3);
            border: 1px solid var(--border2);
            border-radius: 12px;
            transition: all .2s;
        }

        .slider:before {
            content: '';
            position: absolute;
            width: 18px; height: 18px;
            left: 2px; top: 2px;
            background: var(--muted);
            border-radius: 50%;
            transition: all .2s;
        }

        .toggle input:checked + .slider { background: rgba(0,229,160,0.15); border-color: var(--accent); }
        .toggle input:checked + .slider:before { transform: translateX(18px); background: var(--accent); }
        .toggle-label { font-size: 15px; font-weight: 500; color: var(--text); }

        .parlay-field { display: none; }
        .parlay-field.visible { display: block; }

        /* SUBMIT */
        .form-actions { display: flex; gap: 12px; margin-top: 8px; }

        .btn-submit {
            background: var(--accent);
            color: #000;
            border: none;
            padding: 14px 30px;
            border-radius: 6px;
            font-family: 'Barlow', sans-serif;
            font-size: 14px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            flex: 1;
            transition: opacity .2s, transform .15s;
        }

        .btn-submit:hover { opacity: 0.85; transform: translateY(-1px); }

        .btn-cancel {
            background: transparent;
            color: var(--muted);
            border: 1px solid var(--border2);
            padding: 14px 22px;
            border-radius: 6px;
            font-family: 'Barlow', sans-serif;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            text-decoration: none;
            display: flex;
            align-items: center;
            transition: color .15s;
        }

        .btn-cancel:hover { color: var(--text); }

        /* PREVIEW SIDEBAR */
        .preview-sidebar { padding: 28px 22px; background: var(--bg2); }

        .preview-card {
            background: var(--bg3);
            border: 1px solid var(--border2);
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .preview-tag {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 12px;
        }

        .preview-player {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 900;
            font-size: 26px;
            text-transform: uppercase;
            line-height: 1;
            margin-bottom: 4px;
            min-height: 30px;
            color: var(--text);
        }

        .preview-player.placeholder { color: rgba(255,255,255,0.12); }

        .preview-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px solid var(--border);
            gap: 8px;
        }

        .preview-type {
            background: rgba(255,255,255,0.06);
            border: 1px solid var(--border2);
            color: var(--text);
            font-size: 14px;
            font-weight: 700;
            padding: 6px 14px;
            border-radius: 5px;
            letter-spacing: 1px;
            min-width: 52px;
            text-align: center;
        }

        .preview-ou {
            font-size: 12px;
            font-weight: 700;
            padding: 5px 10px;
            border-radius: 4px;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .preview-ou.over  { background: rgba(0,229,160,0.1); color: var(--over); border: 1px solid rgba(0,229,160,0.25); }
        .preview-ou.under { background: rgba(255,77,109,0.1); color: var(--under); border: 1px solid rgba(255,77,109,0.3); }

        .preview-value {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 900;
            font-size: 30px;
            color: var(--gold);
        }

        .preview-value.placeholder { color: rgba(255,255,255,0.12); }

        .ref-title {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 12px;
        }

        .type-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 7px 0;
            border-bottom: 1px solid var(--border);
            font-size: 12px;
        }

        .type-code {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: 0.5px;
        }

        .type-full { color: var(--muted); }
    </style>
</head>
<body>

    <nav>
        <a class="logo" asp-controller="Home" asp-action="Index">
            <div class="logo-dot"></div>
            PropTracker
        </a>
        <ul class="nav-links">
            <li><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li><a asp-controller="Prop" asp-action="Index">Props</a></li>
            <li><a asp-controller="Parlay" asp-action="Index">Parlays</a></li>
        </ul>
        <a class="nav-back" asp-controller="Home" asp-action="Index">← Dashboard</a>
    </nav>

    <div class="page-layout">
        <div class="form-area">
            <div class="page-eyebrow">New Entry</div>
            <h1 class="page-title">Add Prop</h1>

            <form asp-action="Create" method="post" id="propForm">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="PropType"  id="PropTypeHidden" />
                <input type="hidden" asp-for="OverUnder" id="OverUnderHidden" value="Over" />
                <input type="hidden" asp-for="BdlPlayerId" id="BdlPlayerIdHidden" />

                <!-- PLAYER SEARCH -->
                <div class="section-label">Player</div>

                <div class="player-search-wrap">
                    <input type="text"
                           class="player-search-input"
                           id="playerSearchInput"
                           placeholder="Search by player name (e.g. LeBron James)..."
                           autocomplete="off"
                           oninput="onPlayerSearch(this.value)" />
                    <div class="search-spinner" id="searchSpinner"></div>
                    <div class="player-dropdown" id="playerDropdown"></div>
                </div>

                <div class="player-selected-badge" id="selectedBadge">
                    <span class="player-selected-name" id="selectedName"></span>
                    <button type="button" class="player-clear" onclick="clearPlayer()" title="Clear">✕</button>
                </div>
                <div class="player-hint" id="playerHint">
                    Search to link this prop to the BallDontLie API for auto stat checking.
                    Name fields below will be filled automatically.
                </div>

                <div class="form-grid" style="margin-top:16px;">
                    <div class="form-group">
                        <label asp-for="PlayerFirstName">First Name</label>
                        <input asp-for="PlayerFirstName"
                               type="text"
                               id="PlayerFirstName"
                               placeholder="e.g. LeBron"
                               oninput="updatePreview()"
                               class="@(ViewData.ModelState["PlayerFirstName"]?.Errors.Count > 0 ? "input-error" : "")" />
                        <span asp-validation-for="PlayerFirstName" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="PlayerLastName">Last Name</label>
                        <input asp-for="PlayerLastName"
                               type="text"
                               id="PlayerLastName"
                               placeholder="e.g. James"
                               oninput="updatePreview()"
                               class="@(ViewData.ModelState["PlayerLastName"]?.Errors.Count > 0 ? "input-error" : "")" />
                        <span asp-validation-for="PlayerLastName" class="field-validation-error"></span>
                    </div>
                </div>

                <hr class="divider" />

                <!-- BET TYPE -->
                <div class="section-label">Prop Type</div>

                @if (ViewData.ModelState["PropType"]?.Errors.Count > 0)
                {
                    <div class="field-validation-error" style="margin-bottom:12px;">Please select a prop type.</div>
                }

                <div class="bet-type-grid">
                    @foreach (Prop.BetType betType in Enum.GetValues(typeof(Prop.BetType)))
                    {
                        var displayLabels = new Dictionary<Prop.BetType, (string Short, string Full)>
                        {
                            [Prop.BetType.PTS]       = ("PTS",  "Points"),
                            [Prop.BetType.AST]       = ("AST",  "Assists"),
                            [Prop.BetType.REB]       = ("REB",  "Rebounds"),
                            [Prop.BetType.PRA]       = ("PRA",  "Pts+Reb+Ast"),
                            [Prop.BetType.PA]        = ("PA",   "Pts+Ast"),
                            [Prop.BetType.PR]        = ("PR",   "Pts+Reb"),
                            [Prop.BetType.AR]        = ("AR",   "Ast+Reb"),
                            [Prop.BetType.THREEMADE] = ("3PM",  "Threes Made"),
                            [Prop.BetType.DD]        = ("DD",   "Double-Double"),
                            [Prop.BetType.TD]        = ("TD",   "Triple-Double"),
                        };

                        var label = displayLabels[betType];
                        var isSelected = Model?.PropType == betType;

                        <div class="bet-type-btn @(isSelected ? "selected" : "")"
                             onclick="selectType('@betType.ToString()', '@label.Short')"
                             data-value="@betType.ToString()">
                            @label.Short
                            <span class="bet-type-sub">@label.Full</span>
                        </div>
                    }
                </div>

                <hr class="divider" />

                <!-- PROP VALUE + OVER/UNDER -->
                <div class="section-label">Prop Value</div>

                @if (ViewData.ModelState["OverUnder"]?.Errors.Count > 0)
                {
                    <div class="field-validation-error" style="margin-bottom:12px;">Please select Over or Under.</div>
                }

                <div class="value-ou-row">
                    <div class="form-group">
                        <label asp-for="PropValue">Line</label>
                        <div class="value-wrap">
                            <span class="value-prefix">#</span>
                            <input asp-for="PropValue"
                                   type="number"
                                   placeholder="0.0"
                                   step="0.5"
                                   min="0"
                                   id="PropValue"
                                   class="value-input @(ViewData.ModelState["PropValue"]?.Errors.Count > 0 ? "input-error" : "")"
                                   oninput="updatePreview()" />
                        </div>
                        <span asp-validation-for="PropValue" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label>Over / Under</label>
                        <div class="ou-toggle">
                            <button type="button"
                                    class="ou-btn over @(Model?.OverUnder == Prop.OverUnderType.Over ? "selected" : "")"
                                    id="ouOver"
                                    onclick="selectOU('Over')">Over</button>
                            <button type="button"
                                    class="ou-btn under @(Model?.OverUnder == Prop.OverUnderType.Under ? "selected" : "")"
                                    id="ouUnder"
                                    onclick="selectOU('Under')">Under</button>
                        </div>
                    </div>
                </div>

                <hr class="divider" />

                <!-- PARLAY -->
                <div class="section-label">Parlay</div>

                <div class="toggle-row">
                    <label class="toggle">
                        <input type="checkbox" id="parlayToggle" onchange="toggleParlay(this.checked)" />
                        <span class="slider"></span>
                    </label>
                    <span class="toggle-label">Add to a Parlay</span>
                </div>

                <div class="parlay-field @(Model?.ParlayId > 0 ? "visible" : "")" id="parlayField">
                    <div class="form-group">
                        <label asp-for="ParlayId">Parlay ID</label>
                        <input asp-for="ParlayId"
                               type="number"
                               placeholder="Enter existing Parlay ID"
                               min="1"
                               oninput="updatePreview()" />
                        <span asp-validation-for="ParlayId" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="form-actions" style="margin-top:28px;">
                    <button type="submit" class="btn-submit">Save Prop →</button>
                    <a class="btn-cancel" asp-controller="Home" asp-action="Index">Cancel</a>
                </div>
            </form>
        </div>

        <!-- PREVIEW SIDEBAR -->
        <aside class="preview-sidebar">
            <div class="ref-title" style="margin-bottom:14px;">Live Preview</div>

            <div class="preview-card">
                <div class="preview-tag">Prop &middot; <span id="prevParlay">No Parlay</span></div>
                <div class="preview-player placeholder" id="prevPlayer">Player Name</div>
                <div class="preview-row">
                    <div class="preview-type" id="prevType">—</div>
                    <div class="preview-ou over" id="prevOu">Over</div>
                    <div class="preview-value placeholder" id="prevValue">—</div>
                </div>
            </div>

            <div class="ref-title">Prop Type Reference</div>
            <div>
                <div class="type-row"><span class="type-code">PTS</span><span class="type-full">Points</span></div>
                <div class="type-row"><span class="type-code">AST</span><span class="type-full">Assists</span></div>
                <div class="type-row"><span class="type-code">REB</span><span class="type-full">Rebounds</span></div>
                <div class="type-row"><span class="type-code">PRA</span><span class="type-full">Pts + Reb + Ast</span></div>
                <div class="type-row"><span class="type-code">PA</span><span class="type-full">Pts + Ast</span></div>
                <div class="type-row"><span class="type-code">PR</span><span class="type-full">Pts + Reb</span></div>
                <div class="type-row"><span class="type-code">AR</span><span class="type-full">Ast + Reb</span></div>
                <div class="type-row"><span class="type-code">3PM</span><span class="type-full">Threes Made</span></div>
                <div class="type-row"><span class="type-code">DD</span><span class="type-full">Double-Double</span></div>
                <div class="type-row"><span class="type-code">TD</span><span class="type-full">Triple-Double</span></div>
            </div>
        </aside>
    </div>

    @section Scripts {
        @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    }

    <script>
        let selectedTypeDisplay = null;
        let selectedOU = 'Over';
        let searchTimeout = null;

        // Restore state on validation failure
        (function () {
            const hidden = document.getElementById('PropTypeHidden');
            if (hidden?.value) {
                const btn = document.querySelector(`.bet-type-btn[data-value="${hidden.value}"]`);
                if (btn) {
                    btn.classList.add('selected');
                    selectedTypeDisplay = btn.querySelector('.bet-type-sub')
                        ? btn.childNodes[0].textContent.trim()
                        : btn.textContent.trim();
                }
            }
            const ouHidden = document.getElementById('OverUnderHidden');
            if (ouHidden?.value) selectOU(ouHidden.value, false);

            const parlayId = document.getElementById('ParlayId');
            if (parlayId?.value && parseInt(parlayId.value) > 0) {
                document.getElementById('parlayToggle').checked = true;
                document.getElementById('parlayField').classList.add('visible');
            }
            updatePreview();
        })();

        // ── Player search ────────────────────────────────────────────────

        function onPlayerSearch(val) {
            clearTimeout(searchTimeout);
            const dropdown = document.getElementById('playerDropdown');

            if (val.length < 2) {
                dropdown.style.display = 'none';
                return;
            }

            document.getElementById('searchSpinner').style.display = 'block';

            searchTimeout = setTimeout(async () => {
                try {
                    const res = await fetch(`/Prop/SearchPlayers?name=${encodeURIComponent(val)}`);
                    const players = await res.json();

                    document.getElementById('searchSpinner').style.display = 'none';

                    if (!players.length) {
                        dropdown.innerHTML = '<div class="player-option"><span style="color:var(--muted);font-size:13px;">No players found</span></div>';
                    } else {
                        dropdown.innerHTML = players.map(p => `
                            <div class="player-option" onclick="selectPlayer(${p.id},'${esc(p.firstName)}','${esc(p.lastName)}','${esc(p.team)}')">
                                <span class="player-option-name">${esc(p.firstName)} ${esc(p.lastName)}</span>
                                <span class="player-option-team">${esc(p.team)}</span>
                            </div>
                        `).join('');
                    }

                    dropdown.style.display = 'block';
                } catch {
                    document.getElementById('searchSpinner').style.display = 'none';
                }
            }, 350);
        }

        function selectPlayer(id, firstName, lastName, team) {
            document.getElementById('BdlPlayerIdHidden').value = id;
            document.getElementById('PlayerFirstName').value   = firstName;
            document.getElementById('PlayerLastName').value    = lastName;
            document.getElementById('playerSearchInput').value = '';
            document.getElementById('playerDropdown').style.display = 'none';

            const badge = document.getElementById('selectedBadge');
            document.getElementById('selectedName').textContent = `${firstName} ${lastName} (${team})`;
            badge.classList.add('visible');
            document.getElementById('playerHint').style.display = 'none';

            updatePreview();
        }

        function clearPlayer() {
            document.getElementById('BdlPlayerIdHidden').value  = '';
            document.getElementById('PlayerFirstName').value    = '';
            document.getElementById('PlayerLastName').value     = '';
            document.getElementById('playerSearchInput').value  = '';
            document.getElementById('selectedBadge').classList.remove('visible');
            document.getElementById('playerHint').style.display = 'block';
            updatePreview();
        }

        // Close dropdown on outside click
        document.addEventListener('click', e => {
            if (!e.target.closest('.player-search-wrap'))
                document.getElementById('playerDropdown').style.display = 'none';
        });

        // ── Prop type ────────────────────────────────────────────────────

        function selectType(enumVal, displayShort) {
            selectedTypeDisplay = displayShort;
            document.getElementById('PropTypeHidden').value = enumVal;
            document.querySelectorAll('.bet-type-btn').forEach(b => {
                b.classList.toggle('selected', b.dataset.value === enumVal);
            });
            document.getElementById('prevType').textContent = displayShort;
            updatePreview();
        }

        // ── Over / Under ─────────────────────────────────────────────────

        function selectOU(val, updatePrev = true) {
            selectedOU = val;
            document.getElementById('OverUnderHidden').value = val;
            document.getElementById('ouOver').classList.toggle('selected',  val === 'Over');
            document.getElementById('ouUnder').classList.toggle('selected', val === 'Under');
            if (updatePrev) updatePreview();
        }

        // ── Parlay toggle ────────────────────────────────────────────────

        function toggleParlay(on) {
            document.getElementById('parlayField').classList.toggle('visible', on);
            if (!on) document.getElementById('ParlayId').value = '';
            updatePreview();
        }

        // ── Live preview ─────────────────────────────────────────────────

        function updatePreview() {
            const fn  = document.getElementById('PlayerFirstName')?.value.trim() || '';
            const ln  = document.getElementById('PlayerLastName')?.value.trim()  || '';
            const val = document.getElementById('PropValue')?.value               || '';
            const parlayOn = document.getElementById('parlayToggle')?.checked;
            const parlayId = document.getElementById('ParlayId')?.value           || '';

            const playerEl = document.getElementById('prevPlayer');
            const full = [fn, ln].filter(Boolean).join(' ').toUpperCase();
            if (full) { playerEl.textContent = full; playerEl.classList.remove('placeholder'); }
            else      { playerEl.textContent = 'Player Name'; playerEl.classList.add('placeholder'); }

            const valEl = document.getElementById('prevValue');
            if (val && parseFloat(val) > 0) {
                valEl.textContent = parseFloat(val).toFixed(1);
                valEl.classList.remove('placeholder');
            } else {
                valEl.textContent = '—';
                valEl.classList.add('placeholder');
            }

            const ouEl = document.getElementById('prevOu');
            ouEl.textContent = selectedOU;
            ouEl.className   = `preview-ou ${selectedOU.toLowerCase()}`;

            const parlayLabel = document.getElementById('prevParlay');
            if (parlayOn && parlayId)  parlayLabel.textContent = 'Parlay #' + parlayId;
            else if (parlayOn)         parlayLabel.textContent = 'Parlay (no ID)';
            else                       parlayLabel.textContent = 'No Parlay';
        }

        function esc(str) {
            return String(str)
                .replace(/&/g,'&amp;').replace(/</g,'&lt;')
                .replace(/>/g,'&gt;').replace(/"/g,'&quot;')
                .replace(/'/g,'&#39;');
        }
    </script>

</body>
</html>
